{
  "name": "@robinbraemer/codemode",
  "version": "0.3.2",
  "description": "Code Mode MCP tools from OpenAPI specs. Two tools (search + execute) replace hundreds of individual MCP tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "benchmark:executors": "tsx scripts/benchmark-executors.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "openapi",
    "codemode",
    "code-mode",
    "sandbox",
    "ai",
    "llm",
    "tools",
    "model-context-protocol"
  ],
  "author": "cnap-tech",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cnap-tech/codemode.git"
  },
  "peerDependencies": {
    "@robinbraemer/llrt": "^0.1.2",
    "isolated-vm": "6",
    "quickjs-emscripten": ">=0.31"
  },
  "peerDependenciesMeta": {
    "@robinbraemer/llrt": {
      "optional": true
    },
    "isolated-vm": {
      "optional": true
    },
    "quickjs-emscripten": {
      "optional": true
    }
  },
  "devDependencies": {
    "@robinbraemer/llrt": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/node": "^24.13.1",
    "hono": "^4.7.6",
    "isolated-vm": "^6.0.2",
    "quickjs-emscripten": "^0.32.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  }
}
